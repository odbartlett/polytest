# =============================================================================
# Polymarket Whale Bot — Environment Configuration
# Copy this file to .env and fill in your actual values.
#
# SIMULATION MODE (default): SIMULATION_MODE=true
#   Only DATABASE_URL and REDIS_URL are required.
#   All Polymarket credentials are optional — no real orders are placed.
#   The bot uses real Polymarket data to identify and track theoretical positions.
#
# LIVE MODE: SIMULATION_MODE=false
#   All POLYMARKET_* credentials are required.
# =============================================================================

# -----------------------------------------------------------------------------
# Simulation Mode (default: true — paper trading, no real orders)
# Set to false only when you have valid credentials and want live trading.
# -----------------------------------------------------------------------------
SIMULATION_MODE=true

# Virtual starting bankroll for simulation (USDC)
SIM_BANKROLL_USDC=10000.0

# Simulated fill slippage fraction added on top of VWAP price (default: 0.1%)
SIM_FILL_SLIPPAGE=0.001

# How often to mark open paper positions to market (minutes, default: 15)
SIM_MARK_INTERVAL_MINUTES=15

# How often to send a full performance report to Telegram (hours, default: 6)
SIM_REPORT_INTERVAL_HOURS=6

# Automatically close paper positions when market resolves (default: true)
SIM_AUTO_CLOSE_ON_RESOLUTION=true

# -----------------------------------------------------------------------------
# Polymarket CLOB API Credentials
# Required only when SIMULATION_MODE=false.
# Obtain from https://polymarket.com → Settings → API Keys
# -----------------------------------------------------------------------------
# POLYMARKET_API_KEY=your-clob-api-key-here
# POLYMARKET_API_SECRET=your-clob-api-secret-here
# POLYMARKET_API_PASSPHRASE=your-clob-api-passphrase-here

# Your Polygon wallet private key (hex, without 0x prefix)
# WARNING: Keep this secret. Never commit this value.
# POLYMARKET_PRIVATE_KEY=your-polygon-private-key-hex-without-0x

# The Polygon wallet address corresponding to the private key above (checksummed)
# POLYMARKET_WALLET_ADDRESS=0xYourPolygonWalletAddress

# Polymarket CLOB REST base URL (default shown)
CLOB_BASE_URL=https://clob.polymarket.com

# Polymarket CLOB WebSocket URL (default shown)
CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/user

# -----------------------------------------------------------------------------
# Bitquery API
# Obtain from https://bitquery.io — used for on-chain trade history (whitelist scoring).
# Optional in simulation mode if you disable whitelist auto-refresh.
# -----------------------------------------------------------------------------
BITQUERY_API_KEY=your-bitquery-api-key-here

# -----------------------------------------------------------------------------
# Polygon RPC (optional in simulation mode)
# Obtain from Alchemy (https://alchemy.com) or Infura
# -----------------------------------------------------------------------------
# POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/your-alchemy-api-key

# -----------------------------------------------------------------------------
# Database
# Async Postgres connection URL (asyncpg driver)
# Format: postgresql+asyncpg://user:password@host:port/dbname
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://botuser:botpassword@localhost:5432/polymarket_bot

# -----------------------------------------------------------------------------
# Redis
# Format: redis://[:password@]host:port[/db]
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Telegram Alerts (optional — alerts are silently skipped if not configured)
# 1. Create a bot via @BotFather on Telegram
# 2. Get your chat ID by messaging @userinfobot
# -----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=1234567890:your-telegram-bot-token-here
# TELEGRAM_CHAT_ID=-1001234567890

# -----------------------------------------------------------------------------
# Risk Parameters (all have sane defaults — only override if needed)
# -----------------------------------------------------------------------------

# Starting bankroll in USDC
BANKROLL_USDC=1000.0

# Maximum exposure per market as a fraction of bankroll (default: 5%)
MAX_PER_MARKET_EXPOSURE_PCT=0.05

# Maximum drawdown before circuit breaker activates (default: 15%)
MAX_DRAWDOWN_PCT=0.15

# Slippage tolerance for liquid markets (default: 2%)
SLIPPAGE_TOLERANCE_LIQUID=0.02

# Slippage tolerance for thin markets (default: 1%)
SLIPPAGE_TOLERANCE_THIN=0.01

# Seconds to wait for an order fill before cancelling (default: 90)
ORDER_FILL_TIMEOUT_SECONDS=90

# Minimum market open interest in USDC to consider trading (default: $50k)
MIN_MARKET_OPEN_INTEREST=50000.0

# Minimum whale trade size in USDC to trigger a signal (default: $500)
MIN_WHALE_TRADE_SIZE=500.0

# Minimum copy trade size in USDC (default: $50)
MIN_COPY_SIZE=50.0

# Minimum hours until market resolution to enter a position (default: 6)
MIN_HOURS_TO_RESOLUTION=6

# Maximum fraction of orderbook depth the bot consumes per trade (default: 20%)
MAX_LIQUIDITY_CONSUMPTION_PCT=0.20

# -----------------------------------------------------------------------------
# Whale Scoring Thresholds
# -----------------------------------------------------------------------------

# Minimum whale score for a wallet to enter the whitelist (default: 55)
WHALE_SCORE_FLOOR=55.0

# Score below which a wallet is removed from the whitelist (default: 45)
WHALE_SCORE_REMOVAL=45.0

# Maximum number of whitelisted wallets (default: 75)
WHITELIST_MAX_SIZE=75

# Minimum resolved markets required to score a wallet (default: 30)
MIN_RESOLVED_MARKETS=30

# Minimum total volume in USDC to consider a wallet (default: $5k)
MIN_TOTAL_VOLUME_USDC=5000.0

# Minimum trade count to consider a wallet (default: 20)
MIN_TRADE_COUNT=20

# Lookback window in days for scoring (default: 90)
LOOKBACK_DAYS=90

# Exponential decay lambda for recency score (default: 0.02)
RECENCY_DECAY_LAMBDA=0.02
